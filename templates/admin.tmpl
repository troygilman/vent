// ============================================================================
// Helpers
// ============================================================================

func formatFormValue(value any) string {
	switch v := value.(type) {
	case time.Time:
		if v.IsZero() {
			return ""
		}
		return v.Format("2006-01-02T15:04")
	default:
		return fmt.Sprintf("%v", value)
	}
}

func parseDateTimeLocal(value string) (time.Time, error) {
	if value == "" {
		return time.Time{}, errors.New("value is required")
	}
	for _, layout := range []string{"2006-01-02T15:04:05", "2006-01-02T15:04", time.RFC3339} {
		parsed, err := time.Parse(layout, value)
		if err == nil {
			return parsed, nil
		}
	}
	return time.Time{}, fmt.Errorf("must use datetime-local or RFC3339 format")
}

func GetUser(ctx context.Context) (*{{ $userSchema }}, error) {
    user, ok := ctx.Value(userContextKey{}).(*{{ $userSchema }})
	if !ok {
	    return nil, errors.New("user not found in context")
	}
	return user, nil
}

func GetClaims(ctx context.Context) (*auth.VentClaims, error) {
    claims, ok := ctx.Value(claimsContextKey{}).(*auth.VentClaims)
	if !ok {
	    return nil, errors.New("claims not found in context")
	}
	return claims, nil
}

// ============================================================================
// Middleware
// ============================================================================

type claimsContextKey struct{}
type userContextKey struct{}

func NewAuthenticationMiddleware(authenticator auth.TokenAuthenticator) func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			tokenCookie, err := r.Cookie("vent-auth-token")
			if err != nil {
				http.Redirect(w, r, adminBasePath+"login/", http.StatusSeeOther)
				return
			}

			claims, err := authenticator.Authenticate(tokenCookie.Value)
			if err != nil {
				http.Redirect(w, r, adminBasePath+"login/", http.StatusSeeOther)
				return
			}

			ctx := context.WithValue(r.Context(), claimsContextKey{}, claims)
			r = r.WithContext(ctx)
			next.ServeHTTP(w, r)
		})
	}
}

func NewUserMiddleware(client *Client) func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			claims, err := GetClaims(r.Context())
			if err != nil {
			    http.Error(w, err.Error(), http.StatusInternalServerError)
				return
			}

			userID, err := strconv.Atoi(claims.Subject)
			if err != nil {
				http.Error(w, "claims ID is not an int", http.StatusInternalServerError)
				return
			}

			user, err := client.{{ $userSchema }}.Query().
				Where({{ lower $userSchema }}.IDEQ(userID)).
				WithGroups(func(q *{{ $groupSchema }}Query) {
					q.WithPermissions()
				}).
				Only(r.Context())
			if err != nil {
				http.Error(w, "could not find user", http.StatusInternalServerError)
				return
			}

			ctx := context.WithValue(r.Context(), userContextKey{}, user)
			r = r.WithContext(ctx)
			next.ServeHTTP(w, r)
		})
	}
}

func NewStaffMiddleware() func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			user, err := GetUser(r.Context())
			if err != nil {
			    http.Error(w, err.Error(), http.StatusInternalServerError)
				return
			}
			if !user.IsStaff {
				http.Error(w, "user is not staff", http.StatusForbidden)
				return
			}
			next.ServeHTTP(w, r)
		})
	}
}

func NewAuthorizationMiddleware(permissions ...string) func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			user, err := GetUser(r.Context())
			if err != nil {
			    http.Error(w, err.Error(), http.StatusInternalServerError)
				return
			}

			if !user.IsSuperuser {
				userPermissions := make(map[string]struct{})
				for _, group := range user.Edges.Groups {
					for _, permission := range group.Edges.Permissions {
						userPermissions[permission.Name] = struct{}{}
					}
				}

				for _, permission := range permissions {
					if _, ok := userPermissions[permission]; !ok {
						http.Error(w, fmt.Sprintf("user does not have permission: %s", permission), http.StatusForbidden)
						return
					}
				}
			}

			next.ServeHTTP(w, r)
		})
	}
}

func newLoggerMiddleware() func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			log.Printf("%s %s\n", r.Method, r.RequestURI)
			next.ServeHTTP(w, r)
		})
	}
}

