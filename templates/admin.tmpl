// AdminConfig contains configuration for the admin handler
type AdminConfig struct {
	Client                  *Client
	SecretProvider          auth.SecretProvider
	CredentialAuthenticator auth.CredentialAuthenticator
	CredentialGenerator     auth.CredentialGenerator
	SecureCookies           bool

	// FieldTransforms is a registry of transform functions for custom field mappings.
	// Keys are transform names (e.g., "hash"), values are transform functions.
	// If nil, a default registry will be created with built-in transforms.
	FieldTransforms map[string]vent.FieldTransformFunc
}

// AdminHandler is the main HTTP handler for the admin panel
type AdminHandler struct {
	mux                     *http.ServeMux
	client                  *Client
	credentialAuthenticator auth.CredentialAuthenticator
	credentialGenerator     auth.CredentialGenerator
	tokenGenerator          auth.TokenGenerator
	secureCookies           bool
	fieldTransforms         map[string]vent.FieldTransformFunc
	authMiddleware          func(http.Handler) http.Handler
	userMiddleware          func(http.Handler) http.Handler
	staffMiddleware  func(http.Handler) http.Handler
	loggerMiddleware func(http.Handler) http.Handler
}

const adminBasePath = "{{ $adminPath }}"

// NewAdminHandler creates a new admin handler with the given configuration
func NewAdminHandler(config AdminConfig) (*AdminHandler, error) {
	if err := validateAdminConfig(config); err != nil {
		return nil, err
	}

	tokenAuthenticator := auth.NewJwtTokenAuthenticator(config.SecretProvider)

	// Initialize field transforms registry
	fieldTransforms := config.FieldTransforms
	if fieldTransforms == nil {
		fieldTransforms = make(map[string]vent.FieldTransformFunc)
	}

	// Register built-in "hash" transform if CredentialGenerator is provided
	if config.CredentialGenerator != nil {
		if _, exists := fieldTransforms["hash_password"]; !exists {
			fieldTransforms["hash_password"] = func(value any) (any, error) {
				str, ok := value.(string)
				if !ok {
					return nil, errors.New("hash transform requires string value")
				}
				if str == "" {
					return nil, nil // Skip empty passwords
				}
				return config.CredentialGenerator.Generate(str)
			}
		}
	}

	h := &AdminHandler{
		mux:                     http.NewServeMux(),
		client:                  config.Client,
		credentialAuthenticator: config.CredentialAuthenticator,
		credentialGenerator:     config.CredentialGenerator,
		tokenGenerator:          auth.NewJwtTokenGenerator(config.SecretProvider),
		secureCookies:           config.SecureCookies,
		fieldTransforms:         fieldTransforms,
		authMiddleware:          NewAuthenticationMiddleware(tokenAuthenticator),
		userMiddleware:          NewUserMiddleware(config.Client),
		staffMiddleware:         NewStaffMiddleware(),
		loggerMiddleware:        newLoggerMiddleware(),
	}

	// Unauthorized routes
	h.handle("GET "+adminBasePath+"static/", http.StripPrefix(adminBasePath, vent.StaticDirHandler()))
	h.handle("GET "+adminBasePath+"login/", h.getLoginHandler(), h.loggerMiddleware)
	h.handle("POST "+adminBasePath+"login/", h.postLoginHandler(), h.loggerMiddleware)
	h.handle("GET "+adminBasePath+"logout/", h.getLogoutHandler(), h.loggerMiddleware)

	// Authorized routes - admin home
	h.handle("GET "+adminBasePath, h.getAdminHandler(), h.loggerMiddleware, h.authMiddleware, h.userMiddleware, h.staffMiddleware)

	// Schema routes
	{{ range $item := $adminNodes }}
	{{ $node := $item.Node }}
	{{ $rc := $item.RC }}
	{{ $permSuffix := resourceName $node.Name }}
	h.handle("GET "+adminBasePath+"{{ $rc.RouteName }}/", h.get{{ $node.Name }}ListHandler(), h.loggerMiddleware, h.authMiddleware, h.userMiddleware, h.staffMiddleware, NewAuthorizationMiddleware("read_{{ $permSuffix }}"))
	h.handle("POST "+adminBasePath+"{{ $rc.RouteName }}/", h.post{{ $node.Name }}Handler(), h.loggerMiddleware, h.authMiddleware, h.userMiddleware, h.staffMiddleware, NewAuthorizationMiddleware("create_{{ $permSuffix }}"))
	h.handle("GET "+adminBasePath+"{{ $rc.RouteName }}/add/", h.get{{ $node.Name }}AddHandler(), h.loggerMiddleware, h.authMiddleware, h.userMiddleware, h.staffMiddleware, NewAuthorizationMiddleware("create_{{ $permSuffix }}"))
	h.handle("GET "+adminBasePath+"{{ $rc.RouteName }}/{id}/", h.get{{ $node.Name }}Handler(), h.loggerMiddleware, h.authMiddleware, h.userMiddleware, h.staffMiddleware, NewAuthorizationMiddleware("read_{{ $permSuffix }}"))
	h.handle("PATCH "+adminBasePath+"{{ $rc.RouteName }}/{id}/", h.patch{{ $node.Name }}Handler(), h.loggerMiddleware, h.authMiddleware, h.userMiddleware, h.staffMiddleware, NewAuthorizationMiddleware("update_{{ $permSuffix }}"))
	h.handle("DELETE "+adminBasePath+"{{ $rc.RouteName }}/{id}/", h.delete{{ $node.Name }}Handler(), h.loggerMiddleware, h.authMiddleware, h.userMiddleware, h.staffMiddleware, NewAuthorizationMiddleware("delete_{{ $permSuffix }}"))
	{{ end }}

	return h, nil
}

func validateAdminConfig(config AdminConfig) error {
	var errs []string
	if config.Client == nil {
		errs = append(errs, "Client is required")
	}
	if config.SecretProvider == nil {
		errs = append(errs, "SecretProvider is required")
	}
	if config.CredentialAuthenticator == nil {
		errs = append(errs, "CredentialAuthenticator is required")
	}
	if config.CredentialGenerator == nil {
		errs = append(errs, "CredentialGenerator is required")
	}
	if len(errs) > 0 {
		return fmt.Errorf("invalid admin config: %s", strings.Join(errs, "; "))
	}
	return nil
}

func (h *AdminHandler) ServeHTTP(w http.ResponseWriter, r *http.Request) {
	h.mux.ServeHTTP(w, r)
}

func (h *AdminHandler) handle(pattern string, handler http.Handler, middleware ...func(http.Handler) http.Handler) {
	for i := len(middleware) - 1; i >= 0; i-- {
		handler = middleware[i](handler)
	}
	h.mux.Handle(pattern, handler)
	log.Printf("Registered handler on %s", pattern)
}

// buildLayoutProps creates LayoutProps with schema metadata
func (h *AdminHandler) buildLayoutProps(activeSchemaName string) gui.LayoutProps {
	schemas := []gui.SchemaMetadata{
		{{ range $item := $adminNodes }}
		{{ $node := $item.Node }}
		{{ $rc := $item.RC }}
		{Name: "{{ $node.Name }}", DisplayName: "{{ $rc.PluralDisplayName }}", Path: adminBasePath + "{{ $rc.RouteName }}/"},
		{{ end }}
	}
	slices.SortFunc(schemas, func(a, b gui.SchemaMetadata) int {
		return cmp.Compare(a.Name, b.Name)
	})
	return gui.LayoutProps{
		AdminPath:        adminBasePath,
		Schemas:          schemas,
		ActiveSchemaName: activeSchemaName,
	}
}

// handleError logs the error and sends an appropriate HTTP response
func handleError(w http.ResponseWriter, r *http.Request, err error, status int) {
	log.Printf("Error [%s %s]: %v", r.Method, r.URL.Path, err)
	http.Error(w, err.Error(), status)
}

// getLoginHandler returns the handler for GET /admin/login/
func (h *AdminHandler) getLoginHandler() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		props := gui.LoginProps{
			AdminPath: adminBasePath,
		}
		if err := gui.LoginPage(props).Render(r.Context(), w); err != nil {
			handleError(w, r, err, http.StatusInternalServerError)
		}
	})
}

// getLogoutHandler returns the handler for GET /admin/logout/
func (h *AdminHandler) getLogoutHandler() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		http.SetCookie(w, &http.Cookie{
			Name:     "vent-auth-token",
			Value:    "",
			Path:     adminBasePath,
			MaxAge:   -1,
			HttpOnly: true,
			Secure:   h.secureCookies,
			SameSite: http.SameSiteLaxMode,
		})
		http.Redirect(w, r, adminBasePath+"login/", http.StatusSeeOther)
	})
}

// postLoginHandler returns the handler for POST /admin/login/
func (h *AdminHandler) postLoginHandler() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		var signals struct {
			Email    string `json:"email"`
			Password string `json:"password"`
		}
		if err := datastar.ReadSignals(r, &signals); err != nil {
			handleError(w, r, err, http.StatusBadRequest)
			return
		}

		loginProps := gui.LoginProps{
			AdminPath: adminBasePath,
		}

		err := func() error {
			// Find user by email - direct ent query, type-safe
			user, err := h.client.{{ $userSchema }}.Query().
				Where({{ lower $userSchema }}.EmailEQ(signals.Email)).
				Only(r.Context())
			if err != nil {
				loginProps.EmailError = "User with this email does not exist"
				return errors.New("invalid email")
			}

			if !user.IsActive {
				loginProps.EmailError = "User account is inactive"
				return errors.New("inactive user")
			}
			if !user.IsStaff {
				loginProps.EmailError = "User does not have admin access"
				return errors.New("non-staff user")
			}

			// Verify password - direct field access, type-safe
			if err := h.credentialAuthenticator.Authenticate(signals.Password, user.PasswordHash); err != nil {
				loginProps.PasswordErrors = append(loginProps.PasswordErrors, "Password is invalid")
				return err
			}

			// Generate token
			claims := auth.NewClaims(user.ID)
			token, err := h.tokenGenerator.Generate(claims)
			if err != nil {
				return err
			}

			// Set cookie
			maxAge := int(time.Until(claims.ExpiresAt.Time).Seconds())
			if maxAge < 0 {
				maxAge = 0
			}
			http.SetCookie(w, &http.Cookie{
				Name:     "vent-auth-token",
				Value:    token,
				Path:     adminBasePath,
				Expires:  claims.ExpiresAt.Time,
				MaxAge:   maxAge,
				HttpOnly: true,
				Secure:   h.secureCookies,
				SameSite: http.SameSiteLaxMode,
			})

			return nil
		}()

		sse := datastar.NewSSE(w, r)
		if err != nil {
			log.Println(err)
			if err := sse.PatchElementTempl(gui.LoginPage(loginProps)); err != nil {
				handleError(w, r, err, http.StatusInternalServerError)
			}
		} else {
			if err := sse.Redirect(adminBasePath); err != nil {
				handleError(w, r, err, http.StatusInternalServerError)
			}
		}
	})
}

// getAdminHandler returns the handler for GET /admin/
func (h *AdminHandler) getAdminHandler() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		if r.URL.Path != adminBasePath {
			w.WriteHeader(http.StatusNotFound)
			return
		}

		props := gui.AdminPageProps{
			LayoutProps: h.buildLayoutProps(""),
		}

		if err := gui.AdminPage(props).Render(r.Context(), w); err != nil {
			handleError(w, r, err, http.StatusInternalServerError)
		}
	})
}

