// get{{ $node.Name }}Handler returns the handler for GET /admin/{{ lower $node.Name }}s/{id}/
func (h *AdminHandler) get{{ $node.Name }}Handler() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		id, err := strconv.Atoi(r.PathValue("id"))
		if err != nil {
			handleError(w, r, fmt.Errorf("invalid id"), http.StatusBadRequest)
			return
		}

		e, err := h.client.{{ $node.Name }}.Query().
			Where({{ lower $node.Name }}.IDEQ(id)).
			{{- range $edge := $rc.Edges }}
			With{{ pascal $edge.Name }}().
			{{- end }}
			Only(r.Context())
		if err != nil {
			handleError(w, r, err, http.StatusNotFound)
			return
		}

		// Build selected edge IDs for multi-select fields
		{{- range $edge := $rc.Edges }}
		{{- if not $edge.Unique }}
		{{ lower $edge.Name }}IDs := make(map[int]struct{})
		for _, related := range e.Edges.{{ pascal $edge.Name }} {
			{{ lower $edge.Name }}IDs[related.ID] = struct{}{}
		}
		{{- end }}
		{{- end }}

		fields := []gui.SchemaEntityFieldProps{}

		{{ range $field := $rc.FormFields }}
		{{- if eq $field.Name "id" }}
		fields = append(fields, gui.SchemaEntityFieldProps{
			Name:     "id",
			Label:    "ID",
			Type:     "int",
			Value:    fmt.Sprintf("%d", e.ID),
			Editable: false,
		})
		{{- else if $field.IsEdge }}
		// Load {{ $field.Name }} options
		{
			{{ lower $field.EdgeType }}Entities, err := h.client.{{ $field.EdgeType }}.Query().All(r.Context())
			if err != nil {
				handleError(w, r, err, http.StatusInternalServerError)
				return
			}
			options := make([]gui.SelectOption, len({{ lower $field.EdgeType }}Entities))
			for i, opt := range {{ lower $field.EdgeType }}Entities {
				options[i] = gui.SelectOption{
					Value: opt.ID,
					Label: fmt.Sprintf("%v", opt.{{ $field.EdgeDisplayField }}),
					{{- if $field.EdgeUnique }}
					Selected: e.Edges.{{ pascal $field.Name }} != nil && e.Edges.{{ pascal $field.Name }}.ID == opt.ID,
					{{- else }}
					Selected: func() bool { _, ok := {{ lower $field.Name }}IDs[opt.ID]; return ok }(),
					{{- end }}
				}
			}
			fields = append(fields, gui.SchemaEntityFieldProps{
				Name:     "{{ $field.Name }}",
				Label:    "{{ $field.Label }}",
				Type:     "{{ $field.Type }}",
				Editable: true,
				Options:  options,
			})
		}
		{{- else if eq $field.Type "password" }}
		fields = append(fields, gui.SchemaEntityFieldProps{
			Name:     "{{ $field.Name }}",
			Label:    "{{ $field.Label }}",
			Type:     "password",
			Editable: true,
		})
		{{- else }}
		fields = append(fields, gui.SchemaEntityFieldProps{
			Name:     "{{ $field.Name }}",
			Label:    "{{ $field.Label }}",
			Type:     "{{ $field.Type }}",
			Value:    formatFormValue(e.{{ pascal $field.Name }}),
			Editable: {{ $field.Editable }},
		})
		{{- end }}
		{{ end }}

		props := gui.SchemaEntityProps{
			LayoutProps:   h.buildLayoutProps("{{ $node.Name }}"),
			AdminPath:     adminBasePath,
			RouteName:     "{{ $rc.RouteName }}",
			SchemaName:    "{{ $node.Name }}",
			EntityID:      id,
			EntityDisplay: fmt.Sprintf("%v", e.{{ $rc.DisplayField }}),
			Fields:        fields,
		}

		if err := gui.SchemaEntityPage(props).Render(r.Context(), w); err != nil {
			handleError(w, r, err, http.StatusInternalServerError)
		}
	})
}

// post{{ $node.Name }}Handler returns the handler for POST /admin/{{ lower $node.Name }}s/
func (h *AdminHandler) post{{ $node.Name }}Handler() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		var input {{ $node.Name }}CreateInput
		if err := datastar.ReadSignals(r, &input); err != nil {
			handleError(w, r, err, http.StatusBadRequest)
			return
		}

		builder := h.client.{{ $node.Name }}.Create()

		// Direct fields (no transformation)
		{{- range $field := $rc.DirectFields }}
		{{- if eq $field.Type "time.Time" }}
		{{ pascal $field.Name }}Value, err := parseDateTimeLocal(input.{{ pascal $field.Name }})
		if err != nil {
			handleError(w, r, fmt.Errorf("invalid {{ $field.Name }}: %w", err), http.StatusBadRequest)
			return
		}
		builder.Set{{ pascal $field.Name }}({{ pascal $field.Name }}Value)
		{{- else }}
		builder.Set{{ pascal $field.Name }}(input.{{ pascal $field.Name }})
		{{- end }}
		{{- end }}

		// Mapped fields (with transformation)
		{{- range $field := $rc.MappedFields }}
		{
			transformFunc, ok := h.fieldTransforms["{{ $field.TransformKey }}"]
			if !ok {
				handleError(w, r, errors.New("transform '{{ $field.TransformKey }}' not registered"), http.StatusInternalServerError)
				return
			}
			transformed, err := transformFunc(input.{{ pascal $field.InputName }})
			if err != nil {
				handleError(w, r, err, http.StatusInternalServerError)
				return
			}
			if transformed != nil {
				transformedValue, ok := transformed.({{ $field.OutputType }})
				if !ok {
					handleError(w, r, fmt.Errorf("transform \"{{ $field.TransformKey }}\" returned %T, expected {{ $field.OutputType }}", transformed), http.StatusInternalServerError)
					return
				}
				builder.Set{{ pascal $field.SetterName }}(transformedValue)
			}
		}
		{{- end }}

		{{- range $edge := $rc.Edges }}
		// Add {{ $edge.Name }} edges
		{{- if $edge.Unique }}
		if input.{{ pascal $edge.Name }} != "" {
			id, err := strconv.Atoi(input.{{ pascal $edge.Name }})
			if err != nil {
				handleError(w, r, fmt.Errorf("invalid {{ $edge.Name }} id"), http.StatusBadRequest)
				return
			}
			builder.Set{{ pascal $edge.Name }}ID(id)
		}
		{{- else }}
		if len(input.{{ pascal $edge.Name }}) > 0 {
			ids := make([]int, 0, len(input.{{ pascal $edge.Name }}))
			for _, idStr := range input.{{ pascal $edge.Name }} {
				id, err := strconv.Atoi(idStr)
				if err != nil {
					handleError(w, r, fmt.Errorf("invalid {{ $edge.Name }} id"), http.StatusBadRequest)
					return
				}
				ids = append(ids, id)
			}
			builder.Add{{ $edge.Singular }}IDs(ids...)
		}
		{{- end }}
		{{- end }}

		if _, err := builder.Save(r.Context()); err != nil {
			handleError(w, r, err, http.StatusInternalServerError)
			return
		}

		sse := datastar.NewSSE(w, r)
		sse.Redirect(adminBasePath + "{{ $rc.RouteName }}/")
	})
}

// patch{{ $node.Name }}Handler returns the handler for PATCH /admin/{{ lower $node.Name }}s/{id}/
func (h *AdminHandler) patch{{ $node.Name }}Handler() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		id, err := strconv.Atoi(r.PathValue("id"))
		if err != nil {
			handleError(w, r, fmt.Errorf("invalid id"), http.StatusBadRequest)
			return
		}

		var input {{ $node.Name }}UpdateInput
		if err := datastar.ReadSignals(r, &input); err != nil {
			handleError(w, r, err, http.StatusBadRequest)
			return
		}

		builder := h.client.{{ $node.Name }}.UpdateOneID(id)

		// Direct fields (no transformation)
		{{- range $field := $rc.DirectFields }}
		if input.{{ pascal $field.Name }} != nil {
			{{- if eq $field.Type "time.Time" }}
			{{ pascal $field.Name }}Value, err := parseDateTimeLocal(*input.{{ pascal $field.Name }})
			if err != nil {
				handleError(w, r, fmt.Errorf("invalid {{ $field.Name }}: %w", err), http.StatusBadRequest)
				return
			}
			builder.Set{{ pascal $field.Name }}({{ pascal $field.Name }}Value)
			{{- else }}
			builder.Set{{ pascal $field.Name }}(*input.{{ pascal $field.Name }})
			{{- end }}
		}
		{{- end }}

		// Mapped fields (with transformation)
		{{- range $field := $rc.MappedFields }}
		if input.{{ pascal $field.InputName }} != nil {
			transformFunc, ok := h.fieldTransforms["{{ $field.TransformKey }}"]
			if !ok {
				handleError(w, r, errors.New("transform '{{ $field.TransformKey }}' not registered"), http.StatusInternalServerError)
				return
			}
			transformed, err := transformFunc(*input.{{ pascal $field.InputName }})
			if err != nil {
				handleError(w, r, err, http.StatusInternalServerError)
				return
			}
			if transformed != nil {
				transformedValue, ok := transformed.({{ $field.OutputType }})
				if !ok {
					handleError(w, r, fmt.Errorf("transform \"{{ $field.TransformKey }}\" returned %T, expected {{ $field.OutputType }}", transformed), http.StatusInternalServerError)
					return
				}
				builder.Set{{ pascal $field.SetterName }}(transformedValue)
			}
		}
		{{- end }}

		{{- range $edge := $rc.Edges }}
		// Update {{ $edge.Name }} edges
		{{- if $edge.Unique }}
		if input.{{ pascal $edge.Name }} != nil {
			if *input.{{ pascal $edge.Name }} != "" {
				id, err := strconv.Atoi(*input.{{ pascal $edge.Name }})
				if err != nil {
					handleError(w, r, fmt.Errorf("invalid {{ $edge.Name }} id"), http.StatusBadRequest)
					return
				}
				builder.Set{{ pascal $edge.Name }}ID(id)
			} else {
				builder.Clear{{ pascal $edge.Name }}()
			}
		}
		{{- else }}
		if input.{{ pascal $edge.Name }} != nil {
			builder.Clear{{ pascal $edge.Name }}()
			if len(*input.{{ pascal $edge.Name }}) > 0 {
				ids := make([]int, 0, len(*input.{{ pascal $edge.Name }}))
				for _, idStr := range *input.{{ pascal $edge.Name }} {
					id, err := strconv.Atoi(idStr)
					if err != nil {
						handleError(w, r, fmt.Errorf("invalid {{ $edge.Name }} id"), http.StatusBadRequest)
						return
					}
					ids = append(ids, id)
				}
				builder.Add{{ $edge.Singular }}IDs(ids...)
			}
		}
		{{- end }}
		{{- end }}

		if err := builder.Exec(r.Context()); err != nil {
			handleError(w, r, err, http.StatusInternalServerError)
			return
		}

		sse := datastar.NewSSE(w, r)
		sse.Redirect(adminBasePath + "{{ $rc.RouteName }}/")
	})
}

// delete{{ $node.Name }}Handler returns the handler for DELETE /admin/{{ lower $node.Name }}s/{id}/
func (h *AdminHandler) delete{{ $node.Name }}Handler() http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		id, err := strconv.Atoi(r.PathValue("id"))
		if err != nil {
